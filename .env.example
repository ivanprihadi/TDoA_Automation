# ==================== APPLICATION ====================
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-change-this

# ==================== SERVER ====================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
WORKERS=4

# ==================== PATHS ====================
CONFIG_PATH=./config.json
LOG_DIR=./logs
OUTPUT_DIR=./output
DATA_DIR=./output/recorded_data

# ==================== DATABASE ====================
DATABASE_URL=sqlite:///./tdoa_results.db

# ==================== SSH/REMOTE ====================
SSH_KEY_PATH=~/.ssh/id_rsa
SSH_TIMEOUT=30
SSH_RETRY_COUNT=3

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== SIGNAL PROCESSING ====================
SAMPLE_RATE=2048000
BANDWIDTH_KHZ=40
CORRELATION_TYPE=dphase

# ==================== VISUALIZATION ====================
HEATMAP_RESOLUTION=200
HEATMAP_THRESHOLD=0.70
MAP_TILE_PROVIDER=openstreetmap